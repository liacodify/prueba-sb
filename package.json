		"axios": "^1.18.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"framer-motion": "^12.40.0",
		"lucide-react": "^1.18.0",
		"next": "16.2.9",
		"next-themes": "^0.4.6",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-hook-form": "^7.79.0",
		"recharts": "^3.8.1",
		"shadcn": "^4.11.0",
		"sonner": "^2.0.7",
